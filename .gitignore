# =============================================================================
# Skyzentech.com unified .gitignore
# Top-level legacy PHP site + backend/ (Spring Boot) + frontend/ (Next.js)
# =============================================================================

# === Secrets (CRITICAL) ======================================================
dbconn.php
backend/run-dev.ps1
**/run-dev.ps1
backend/.env
backend/.env.*
frontend/.env.local
frontend/.env*.local
frontend/.env.production

# Office docs frequently used as scratchpad credential notes — never commit.
*.xlsx
*.xls
*.csv
~$*
credentials*
secrets*
# ...but these are UI components, not secret files — keep them tracked.
!**/CredentialsModal.tsx
!**/CredentialsModal.*.tsx

# === Java / Maven (for backend) ==============================================
backend/target/
backend/.mvn/
backend/*.class
backend/dependency-reduced-pom.xml

# === Node / Next.js (for frontend) ===========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel

# === IDE =====================================================================
.idea/
.vscode/
*.iml

# === OS ======================================================================
.DS_Store
Thumbs.db
ehthumbs.db

# === Misc ====================================================================
*.log
*.swp
*~
